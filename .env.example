# =============================================================================
# myAgent — environment template
# Copy:  cp .env.example .env   (or copy manually)
# Fill values locally. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Local / app
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=info

# Your IANA timezone (for "today" boundaries, journal filenames)
TIMEZONE=

# Optional: E.164 phone for filtering or logs (e.g. +15551234567)
USER_PHONE_E164=


# -----------------------------------------------------------------------------
# LLM (set the provider(s) you actually use; rest can stay empty)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=

# Default model id for scripts/tools, e.g. gpt-4o-mini, claude-sonnet-4-20250514
DEFAULT_LLM_MODEL=


# -----------------------------------------------------------------------------
# Google Calendar API (OAuth)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# After OAuth flow, paste refresh token here (keeps working without re-login)
GOOGLE_REFRESH_TOKEN=

# Calendar to write events to: often an email like "abc@group.calendar.google.com"
# or "primary" for main calendar (not recommended for bot blocks)
GOOGLE_CALENDAR_ID=

# Only if you run a local OAuth callback server later, e.g. FastAPI
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback


# -----------------------------------------------------------------------------
# Mem0 (long-term memory)
# -----------------------------------------------------------------------------
MEM0_API_KEY=
MEM0_USER_ID=


# -----------------------------------------------------------------------------
# OpenClaw gateway (if scripts call hooks or the gateway from this machine)
# -----------------------------------------------------------------------------
# WhatsApp: if you use OpenClaw + QR (openclaw channels login --channel whatsapp),
# your session lives under ~/.openclaw/credentials/whatsapp/ — you do NOT fill
# WHATSAPP_* variables below. OpenClaw onboarding handles model keys separately.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_HOOK_TOKEN=


# -----------------------------------------------------------------------------
# WhatsApp — Meta Cloud API (SKIP ENTIRE BLOCK if you use OpenClaw QR)
# -----------------------------------------------------------------------------
# Only needed if you build your own bot against Meta's WhatsApp Business API
# (webhooks, access tokens). OpenClaw's built-in channel does not use these.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_APP_SECRET=
# WHATSAPP_VERIFY_TOKEN=


# -----------------------------------------------------------------------------
# Webhooks / shared secrets (custom integrations, HMAC, etc.)
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Optional: hosting later (Railway, Fly, etc.) — leave blank for local-only
# -----------------------------------------------------------------------------
# PUBLIC_BASE_URL=
